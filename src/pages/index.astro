|---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';
const base = import.meta.env.BASE_URL;
// 正确拼接路径，避免双斜杠
function resolve(path: string) {
  // 移除 base 末尾斜杠，添加路径开头斜杠
  const baseClean = base.endsWith('/') ? base.slice(0, -1) : base;
  return `${baseClean}/${path}`;
}
---

<Layout title="首页" description={SITE.description}>
  <!-- Hero 区域 - 苹果风格简约 -->
  <section class="py-16 md:py-24 text-center">
    <div class="apple-container">
      <h1 class="text-4xl md:text-6xl font-bold mb-6 text-gray-900 dark:text-white">
        欢迎来到<span class="text-apple-blue">健身为王</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 mb-10 max-w-2xl mx-auto">
        个人健身追踪平台，记录每一次训练，见证每一步成长
      </p>

      <!-- 行动按钮 -->
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <a href={base + 'daily'} class="apple-btn-primary px-8 py-3">
          开始今日训练
        </a>
        <a href={base + 'workouts'} class="apple-btn-secondary px-8 py-3">
          浏览训练库
        </a>
      </div>

      <!-- 用户菜单 (登录后显示) -->
      <div id="user-menu" class="hidden mb-8">
        <span class="text-gray-600 dark:text-gray-400 mr-4">
          你好，<span id="username-display" class="font-semibold text-apple-blue"></span>
        </span>
        <button id="logout-btn" class="apple-btn-secondary">退出登录</button>
      </div>
    </div>
  </section>

  <!-- 功能卡片 -->
  <section class="pb-20">
    <div class="apple-container">
      <h2 class="text-3xl font-bold text-center mb-10 text-gray-900 dark:text-white">功能导航</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href={base + 'daily'} class="apple-card p-8 block hover:scale-[1.02] transition-all">
          <div class="text-5xl mb-4">💪</div>
          <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-white">每日训练</h3>
          <p class="text-gray-600 dark:text-gray-400">每天为你推荐精选训练，坚持打卡养成习惯</p>
        </a>

        <a href={base + 'workouts'} class="apple-card p-8 block hover:scale-[1.02] transition-all">
          <div class="text-5xl mb-4">📚</div>
          <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-white">训练库</h3>
          <p class="text-gray-600 dark:text-gray-400">完整的动作库和训练计划，找到适合你的训练</p>
        </a>

        <a href={base + 'challenges'} class="apple-card p-8 block hover:scale-[1.02] transition-all">
          <div class="text-5xl mb-4">🎯</div>
          <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-white">月度挑战</h3>
          <p class="text-gray-600 dark:text-gray-400">参与月度健身挑战，和大家一起坚持</p>
        </a>

        <a href={base + 'programs'} class="apple-card p-8 block hover:scale-[1.02] transition-all">
          <div class="text-5xl mb-4">📅</div>
          <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-white">健身计划</h3>
          <p class="text-gray-600 dark:text-gray-400">创建并管理你的个性化健身计划</p>
        </a>

        <a href={base + 'login'} class="apple-card p-8 block hover:scale-[1.02] transition-all">
          <div class="text-5xl mb-4">🔐</div>
          <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-white">登录/注册</h3>
          <p class="text-gray-600 dark:text-gray-400">登录后同步你的训练数据到云端</p>
        </a>

        <a href={base + 'about'} class="apple-card p-8 block hover:scale-[1.02] transition-all">
          <div class="text-5xl mb-4">ℹ️</div>
          <h3 class="text-xl font-semibold mb-2 text-gray-900 dark:text-white">关于</h3>
          <p class="text-gray-600 dark:text-gray-400">了解更多关于这个项目的信息</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 统计区域 (登录后显示) -->
  <section id="stats-section" class="hidden pb-20">
    <div class="apple-container">
      <h2 class="text-3xl font-bold mb-10 text-center text-gray-900 dark:text-white">我的训练统计</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="apple-card p-8 text-center">
          <div id="total-workouts" class="text-4xl font-bold text-apple-blue">0</div>
          <p class="text-gray-600 dark:text-gray-400 mt-2">总训练次数</p>
        </div>
        <div class="apple-card p-8 text-center">
          <div id="total-days" class="text-4xl font-bold text-apple-blue">0</div>
          <p class="text-gray-600 dark:text-gray-400 mt-2">训练天数</p>
        </div>
        <div class="apple-card p-8 text-center">
          <div id="streak" class="text-4xl font-bold text-apple-blue">0</div>
          <p class="text-gray-600 dark:text-gray-400 mt-2">当前连续天数</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 登录/注册模态框 -->
  <div id="login-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white dark:bg-gray-900 apple-rounded-2xl shadow-2xl max-w-md w-full max-h-[90vh] overflow-y-auto">
      <div class="p-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white" id="modal-title">登录</h3>
          <button onclick="document.getElementById('login-modal').classList.add('hidden')" class="text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <div class="space-y-4">
          <!-- 标签切换 -->
          <div class="flex rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700">
            <button id="tab-login" class="flex-1 py-2 bg-apple-blue text-white font-medium">登录</button>
            <button id="tab-register" class="flex-1 py-2 bg-transparent text-gray-600 dark:text-gray-400 font-medium hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">注册</button>
          </div>

          <!-- 登录表单 -->
          <form id="login-form" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">用户名</label>
              <input type="text" id="login-username" required class="apple-input w-full px-3 py-2">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">密码</label>
              <input type="password" id="login-password" required class="apple-input w-full px-3 py-2">
            </div>
            <button type="submit" class="apple-btn-primary w-full">登录</button>
            <div id="login-error" class="text-red-500 text-sm hidden"></div>
          </form>

          <div class="relative my-4">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-300 dark:border-gray-700"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-2 bg-white dark:bg-gray-900 text-gray-500 dark:text-gray-400">或者使用</span>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <a href={resolve('auth/google')} class="flex items-center justify-center px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
              <span class="sr-only">Google</span>
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.52H2.22v2.83C4.02 20.42 7.55 23 12 23z" fill="#34A853"></path>
