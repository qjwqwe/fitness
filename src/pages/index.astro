</Layout>

<script is:inline>
// 首页 JavaScript - 用户认证状态处理
const api = window.fitnessAPI;

// 检查登录状态
if (api.isAuthenticated()) {
  document.getElementById('login-card').classList.add('hidden');
  document.getElementById('user-menu').classList.remove('hidden');
  document.getElementById('stats-section').classList.remove('hidden');
  
  const user = api.getCurrentUser();
  if (user) {
    document.getElementById('username-display').textContent = user.username;
  }
  
  // 加载统计数据
  loadStats();
}

// 退出登录
document.getElementById('logout-btn')?.addEventListener('click', () => {
  api.logout();
});

// 标签切换
document.getElementById('tab-login')?.addEventListener('click', () => {
  document.getElementById('tab-login').classList.add('bg-blue-600', 'text-white');
  document.getElementById('tab-login').classList.remove('bg-transparent', 'text-gray-600', 'dark:text-gray-400');
  document.getElementById('tab-register').classList.remove('bg-blue-600', 'text-white');
  document.getElementById('tab-register').classList.add('bg-transparent', 'text-gray-600', 'dark:text-gray-400');
  document.getElementById('login-form').classList.remove('hidden');
  document.getElementById('register-form').classList.add('hidden');
  document.getElementById('modal-title').textContent = '登录';
});

document.getElementById('tab-register')?.addEventListener('click', () => {
  document.getElementById('tab-register').classList.add('bg-blue-600', 'text-white');
  document.getElementById('tab-register').classList.remove('bg-transparent', 'text-gray-600', 'dark:text-gray-400');
  document.getElementById('tab-login').classList.remove('bg-blue-600', 'text-white');
  document.getElementById('tab-login').classList.add('bg-transparent', 'text-gray-600', 'dark:text-gray-400');
  document.getElementById('login-form').classList.add('hidden');
  document.getElementById('register-form').classList.remove('hidden');
  document.getElementById('modal-title').textContent = '注册';
});

// 登录提交
document.getElementById('login-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const username = document.getElementById('login-username').value;
  const password = document.getElementById('login-password').value;
  const errorEl = document.getElementById('login-error');
  
  try {
    await api.login(username, password);
    window.location.reload();
  } catch (err) {
    errorEl.textContent = err.message;
    errorEl.classList.remove('hidden');
  }
});

// 注册提交
document.getElementById('register-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const username = document.getElementById('register-username').value;
  const email = document.getElementById('register-email').value;
  const password = document.getElementById('register-password').value;
  const errorEl = document.getElementById('register-error');
  
  // 客户端验证
  if (password.length < 8) {
    errorEl.textContent = '密码至少需要8个字符';
    errorEl.classList.remove('hidden');
    return;
  }
  if (!/(?=.*[a-zA-Z])(?=.*\d)/.test(password)) {
    errorEl.textContent = '密码需要包含至少一个字母和一个数字';
    errorEl.classList.remove('hidden');
    return;
  }
  
  try {
    await api.register(username, email, password);
    window.location.reload();
  } catch (err) {
    errorEl.textContent = err.message;
    errorEl.classList.remove('hidden');
  }
});

// 加载统计数据
async function loadStats() {
  try {
    const { workouts } = await api.getWorkouts();
    document.getElementById('total-workouts').textContent = workouts.length;
    
    // 计算训练天数和连续天数
    const workoutDates = workouts.map(w => new Date(w.date).toDateString());
    const uniqueDays = new Set(workoutDates);
    document.getElementById('total-days').textContent = uniqueDays.size;
    
    // TODO: 计算连续天数
    document.getElementById('streak').textContent = '0';
  } catch (err) {
    console.error('加载统计失败', err);
  }
}
</script>
