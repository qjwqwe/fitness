---
import Layout from '../layouts/Layout.astro';
import presetWorkouts from '../data/fitness/preset-workouts.js';
---

<script is:inline>
// 将预置数据暴露给客户端
window.PRESET_WORKOUTS = JSON.stringify(presetWorkouts);
</script>

<Layout title="每日训练" description="每日为你推荐精选训练，坚持打卡养成习惯">
  <div class="apple-container py-8">
    <h1 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900 dark:text-white">每日训练</h1>

    <div class="mb-6">
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        今天是 <span id="today-date" class="font-semibold"></span>，让我们开始今天的训练吧！
      </p>

      <div class="flex flex-wrap gap-3">
        <button id="generate-btn" class="apple-btn-primary">随机生成今日训练</button>
        <button id="save-btn" class="apple-btn-secondary" disabled>保存到我的记录</button>
      </div>
    </div>

    <!-- 今日训练卡片 -->
    <div id="workout-container" class="apple-card p-6 mb-6">
      <p class="text-gray-500 dark:text-gray-400 italic">点击"随机生成今日训练"开始</p>
    </div>

    <!-- 已完成提示 -->
    <div id="completed-badge" class="hidden mb-6">
      <div class="bg-green-100 dark:bg-green-900/30 border border-green-200 dark:border-green-800 apple-rounded-lg p-4">
        <p class="text-green-700 dark:text-green-300 font-semibold">✅ 今日训练已完成！真棒！</p>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
// 每日训练页面
document.addEventListener('fitnessAPIReady', () => {
  const api = window.fitnessAPI;
  let currentWorkout = null;
  // 从服务端获取预置数据
  const presetWorkouts = JSON.parse(window.PRESET_WORKOUTS);

// 显示今天日期
const today = new Date();
document.getElementById('today-date').textContent = today.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long'
});

// 检查今天是否已经完成训练
checkTodayCompleted();

// 随机生成训练
document.getElementById('generate-btn').addEventListener('click', () => {
  generateDailyWorkout();
});

// 保存训练
document.getElementById('save-btn').addEventListener('click', async () => {
  if (!currentWorkout || !api.isAuthenticated()) {
    alert('请先登录才能保存训练记录');
    return;
  }
  
  try {
    await api.createWorkout({
      name: currentWorkout.name,
      type: 'daily',
      exercises: currentWorkout.exercises,
      duration: currentWorkout.duration,
      date: new Date().toISOString(),
    });
    
    alert('训练保存成功！');
    document.getElementById('completed-badge').classList.remove('hidden');
    document.getElementById('save-btn').disabled = true;
  } catch (err) {
    alert('保存失败: ' + err.message);
  }
});

// 生成随机每日训练
function generateDailyWorkout() {
  const container = document.getElementById('workout-container');
  const categories = Object.keys(presetWorkouts);
  const randomCategory = categories[Math.floor(Math.random() * categories.length)];
  const workoutsInCategory = presetWorkouts[randomCategory];
  const randomWorkout = workoutsInCategory[Math.floor(Math.random() * workoutsInCategory.length)];
  
  currentWorkout = randomWorkout;
  
  let html = `
    <h2 class="text-2xl font-bold mb-2 text-gray-900 dark:text-white">${randomWorkout.name}</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-4">${randomWorkout.description}</p>
    <div class="mb-4 flex flex-wrap gap-2">
      <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full text-sm">${randomWorkout.category}</span>
      <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full text-sm">${randomWorkout.duration} 分钟</span>
      <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full text-sm">难度: ${randomWorkout.difficulty}</span>
    </div>
    <h3 class="text-lg font-semibold mb-3 text-gray-900 dark:text-white">训练动作:</h3>
    <ul class="space-y-2 mb-4">
  `;
  
  randomWorkout.exercises.forEach(exercise => {
    html += `
      <li class="flex items-start">
        <span class="text-blue-600 dark:text-blue-400 font-bold mr-2">•</span>
        <span class="text-gray-800 dark:text-gray-200">${exercise.name} - ${exercise.sets} × ${exercise.reps}</span>
      </li>
    `;
  });
  
  html += `</ul>`;
  
  if (randomWorkout.notes) {
    html += `
      <div class="mt-4 p-3 bg-yellow-50 dark:bg-yellow-900/20 rounded-lg">
        <p class="text-yellow-800 dark:text-yellow-200 text-sm"><strong>提示:</strong> ${randomWorkout.notes}</p>
      </div>
    `;
  }
  
  container.innerHTML = html;
  
  // 启用保存按钮
  document.getElementById('save-btn').disabled = false;
}

// 检查今日是否已完成
async function checkTodayCompleted() {
  if (!api.isAuthenticated()) return;
  
  try {
    const { workouts } = await api.getWorkouts();
    const todayStr = new Date().toDateString();
    const todayWorkout = workouts.find(w => 
      new Date(w.date).toDateString() === todayStr
    );
    
    if (todayWorkout) {
      document.getElementById('completed-badge').classList.remove('hidden');
      document.getElementById('save-btn').disabled = true;
    }
  } catch (err) {
    console.error('检查完成状态失败', err);
  }
}
});
</script>
